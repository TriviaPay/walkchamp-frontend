# Walk Champ — Frontend environment variables
# Copy to .env locally, or set in EAS (eas.json) / Expo dashboard for builds.
#
# ── Replit → new name mapping ─────────────────────────────────────────────────
# Replit / old name                    → Use this name now
# EXPO_PUBLIC_DOMAIN / REPLIT_DOMAINS  → EXPO_PUBLIC_WEB_URL
# API server URL                       → EXPO_PUBLIC_API_URL
# DESCOPE_PROJECT_ID                   → EXPO_PUBLIC_DESCOPE_PROJECT_ID
# PUSHER_KEY                           → EXPO_PUBLIC_PUSHER_KEY
# PUSHER_CLUSTER                       → EXPO_PUBLIC_PUSHER_CLUSTER
# ONESIGNAL_APP_ID                     → EXPO_PUBLIC_ONESIGNAL_APP_ID
# STRIPE publishable key               → EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY
# RAZORPAY key id (public)             → EXPO_PUBLIC_RAZORPAY_KEY_ID

# ── REQUIRED for mobile / split deploy ────────────────────────────────────────
# Your Vercel (or other) backend URL — no trailing slash:
EXPO_PUBLIC_API_URL=https://walkchamp-backend-sooty.vercel.app

# ── Web / OAuth / password reset ───────────────────────────────────────────────
EXPO_PUBLIC_WEB_URL=https://walkchamp.app
EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URL=

# ── Auth (Descope) — same project ID as backend DESCOPE_PROJECT_ID ────────────
EXPO_PUBLIC_DESCOPE_PROJECT_ID=

# ── Real-time (Pusher) — public key + cluster only ───────────────────────────
EXPO_PUBLIC_PUSHER_KEY=
EXPO_PUBLIC_PUSHER_CLUSTER=

# ── Push (OneSignal) — app ID only (REST key stays on backend) ────────────────
EXPO_PUBLIC_ONESIGNAL_APP_ID=

# ── Payments (client-side keys only) ──────────────────────────────────────────
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_TYooMQauvdEDq54NiTzh27Gci
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_T2jKlttzxL1WzR

# ── Ads (AdMob) ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_ADS_ENABLED=true
EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL_ID=ca-app-pub-3940256099942544/1033173712
EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL_ID=ca-app-pub-3940256099942544/4411468910

# ── Deep links ─────────────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_INVITE_URL=https://walkchamp.app/invite

# ── Static web build (optional) ───────────────────────────────────────────────
EXPO_PUBLIC_APP_URL=
PORT=3000
BASE_PATH=/
