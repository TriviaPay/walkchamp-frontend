# Walk Champ — Frontend environment variables
# Copy to .env locally, or set in EAS (eas.json) / Expo dashboard for builds.
#
# Production builds: NEVER put pk_test_ / rzp_test_ / AdMob sample IDs in the
# production EAS profile. Set live public keys via EAS Secrets / dashboard:
#   EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
#   EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_live_...
#   EXPO_PUBLIC_ADMOB_ANDROID_APP_ID / EXPO_PUBLIC_ADMOB_IOS_APP_ID
#   EXPO_PUBLIC_ADMOB_*_BANNER_ID / REWARDED_ID / INTERSTITIAL_ID
#   EXPO_PUBLIC_SENTRY_DSN=https://...@....ingest.sentry.io/...
#   EXPO_PUBLIC_ENABLE_CASH_CHALLENGES=true  (only after live keys + webhooks verified)

# ── Environment marker ────────────────────────────────────────────────────────
# development | preview | production
EXPO_PUBLIC_APP_ENV=development

# ── REQUIRED for mobile / split deploy ────────────────────────────────────────
EXPO_PUBLIC_API_URL=https://api.walkchamp.miragaming.com

# Cash Prize Challenge. Production EAS defaults to false until live payments are ready.
EXPO_PUBLIC_ENABLE_CASH_CHALLENGES=true

# Mirror backend PAYMENTS_LIVE_MODE.
# false = sandbox/test Stripe & Razorpay keys allowed (card testing).
# true  = live keys required; only after legal/provider approvals.
EXPO_PUBLIC_PAYMENTS_LIVE_MODE=false

# Optional: show legacy $1 / $3 / $5 cards in main Join section (off by default).
# EXPO_PUBLIC_ENABLE_LEGACY_CASH_RACE_CARDS=true

# ── Web / OAuth / password reset ───────────────────────────────────────────────
EXPO_PUBLIC_WEB_URL=https://walkchamp.app
EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URL=

# ── Auth (Descope) — same project ID as backend DESCOPE_PROJECT_ID ────────────
EXPO_PUBLIC_DESCOPE_PROJECT_ID=

# ── Real-time (Pusher) — public key + cluster only ───────────────────────────
EXPO_PUBLIC_PUSHER_KEY=
EXPO_PUBLIC_PUSHER_CLUSTER=

# ── Push (OneSignal) — app ID only (REST key stays on backend) ────────────────
EXPO_PUBLIC_ONESIGNAL_APP_ID=

# ── Payments (client-side PUBLIC keys only — never secret keys) ───────────────
# Local/preview may use test keys. Production must use pk_live_ / rzp_live_.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_TYooMQauvdEDq54NiTzh27Gci
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_T2jKlttzxL1WzR

# ── Ads (AdMob) ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_ADS_ENABLED=true
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-3940256099942544~3347511713
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-3940256099942544~1458002511
EXPO_PUBLIC_ADMOB_ANDROID_BANNER_ID=ca-app-pub-3940256099942544/6300978111
EXPO_PUBLIC_ADMOB_IOS_BANNER_ID=ca-app-pub-3940256099942544/2934735716
EXPO_PUBLIC_ADMOB_ANDROID_REWARDED_ID=ca-app-pub-3940256099942544/5224354917
EXPO_PUBLIC_ADMOB_IOS_REWARDED_ID=ca-app-pub-3940256099942544/1712485313
EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL_ID=ca-app-pub-3940256099942544/1033173712
EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL_ID=ca-app-pub-3940256099942544/4411468910

# ── Crash reporting (optional locally; required for production observability) ─
EXPO_PUBLIC_SENTRY_DSN=
# EXPO_PUBLIC_SENTRY_DEBUG=true

# ── Deep links ─────────────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_INVITE_URL=https://walkchamp.app/invite

# ── Static web build (optional) ───────────────────────────────────────────────
EXPO_PUBLIC_APP_URL=
PORT=3000
BASE_PATH=/
